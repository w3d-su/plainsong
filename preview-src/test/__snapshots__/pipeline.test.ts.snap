exports[`markdown preview pipeline > renders the kitchen sink fixture 1`] = `
"<h1 data-line="16">Kitchen Sink Fixture</h1>
<p data-line="18">This document exercises common Markdown and GFM constructs used by Plainsong. It is
intended for editor highlighting, preview rendering, scroll sync, and performance smoke
checks.</p>
<h2 data-line="22">Headings</h2>
<h3 data-line="24">Third Level</h3>
<h4 data-line="26">Fourth Level</h4>
<h5 data-line="28">Fifth Level</h5>
<h6 data-line="30">Sixth Level</h6>
<h2 data-line="32">Emphasis And Inline Spans</h2>
<p data-line="34">Plain text can include <strong>bold</strong>, <em>italic</em>, <em><strong>bold italic</strong></em>, <del>strikethrough</del>, <code>inline code</code>,
and an escaped asterisk like *this*. Smart punctuation stays ordinary in source: "quoted
text", <code>--</code>, and <code>...</code>.</p>
<p data-line="38">Inline math should remain readable in source and render in preview: <span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>E</mi><mo>=</mo><mi>m</mi><msup><mi>c</mi><mn>2</mn></msup></mrow><annotation encoding="application/x-tex">E = mc^2</annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height:0.6833em;"></span><span class="mord mathnormal" style="margin-right:0.0576em;">E</span><span class="mspace" style="margin-right:0.2778em;"></span><span class="mrel">=</span><span class="mspace" style="margin-right:0.2778em;"></span></span><span class="base"><span class="strut" style="height:0.8141em;"></span><span class="mord mathnormal">m</span><span class="mord"><span class="mord mathnormal">c</span><span class="msupsub"><span class="vlist-t"><span class="vlist-r"><span class="vlist" style="height:0.8141em;"><span style="top:-3.063em;margin-right:0.05em;"><span class="pstrut" style="height:2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mtight">2</span></span></span></span></span></span></span></span></span></span></span>.</p>
<h2 data-line="40">Links And Images</h2>
<p data-line="42"><a href="./related-post.md">Relative Markdown link</a></p>
<p data-line="44"><a href="https://example.com/blogeditor">External link</a></p>
<p data-line="46"><img src="./assets/example-image.png" alt="Relative image reference" title="Fixture image"></p>
<p data-line="48">Autolinks should be recognized by GFM: <a href="https://example.com">https://example.com</a> and <a href="mailto:support@example.com">support@example.com</a>.</p>
<h2 data-line="50">Blockquote</h2>
<blockquote data-line="52">
<p data-line="52">A blockquote can contain <strong>formatting</strong> and a link to <a href="#headings">the heading</a>.</p>
<ul data-line="54">
<li data-line="54">Nested quoted list item</li>
<li data-line="55">Another quoted list item</li>
</ul>
</blockquote>
<h2 data-line="57">Lists</h2>
<ul data-line="59">
<li data-line="59">Unordered item</li>
<li data-line="60">Unordered item with nested content
<ul data-line="61">
<li data-line="61">Nested bullet</li>
<li data-line="62">Nested bullet with <code>inline code</code></li>
</ul>
</li>
<li data-line="63">Final unordered item</li>
</ul>
<ol data-line="65">
<li data-line="65">Ordered item</li>
<li data-line="66">Ordered item with nested tasks
<ul class="contains-task-list" data-line="67">
<li class="task-list-item" data-line="67"><input type="checkbox" data-task-checkbox="true"> Draft the section</li>
<li class="task-list-item" data-line="68"><input type="checkbox" checked data-task-checkbox="true"> Review the section</li>
</ul>
</li>
<li data-line="69">Ordered item after nested tasks</li>
</ol>
<ul class="contains-task-list" data-line="71">
<li class="task-list-item" data-line="71"><input type="checkbox" data-task-checkbox="true"> Open the fixture</li>
<li class="task-list-item" data-line="72"><input type="checkbox" checked data-task-checkbox="true"> Confirm task list highlighting</li>
<li class="task-list-item" data-line="73"><input type="checkbox" data-task-checkbox="true"> Toggle this item from preview during M2</li>
</ul>
<h2 data-line="75">Table</h2>
<table data-line="77">
<thead data-line="77">
<tr data-line="77">
<th data-line="77">Feature</th>
<th align="right" data-line="77">Syntax</th>
<th data-line="77">Expected Result</th>
</tr>
</thead>
<tbody data-line="79">
